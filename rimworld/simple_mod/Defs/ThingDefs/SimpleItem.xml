<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="ResourceBase">
    <defName>ShinyRock</defName>
    <label>shiny rock</label>
    <description>A pretty, shiny rock. Doesn't do much, but it's nice to look at.</description>
    <graphicData>
      <texPath>Things/Item/Resource/Gold</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
