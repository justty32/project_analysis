      <MarketValue>10.0</MarketValue>
      <Mass>0.5</Mass>
    </statBases>
    <thingCategories>
      <li>Items</li>
    </thingCategories>
    <stackLimit>50</stackLimit>
    <comps>
      <li>
        <compClass>SimpleItemMod.CompShinyRock</compClass>
      </li>
    </comps>
  </ThingDef>
</Defs>
