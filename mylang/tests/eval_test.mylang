// Test Math
print (+ 1 2 3)
print (- 10 2 1)
print (* 2 3 4)
print (/ 100 2 5)

// Test Logic
print (and true 1 "hello")
print (and true false 1)
print (or false 0 "fallback")
print (or false true)
print (not true)
print (not false)

// Test Comparison
print (eq 10 10)
print (eq "hi" "hi")
print (lt 5 10)
print (gt 10 5)
print (le 5 5)
print (ge 10 10)

// Test Macro (def_macro)
def_macro unless (cond body)
	list 'if cond nil body

unless (gt 5 10)
	print "5 is not greater than 10"

// Test exec
def code '(print "Executed from list")
exec code
