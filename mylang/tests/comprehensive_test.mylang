// 1. Recursive Function
def_func factorial (n)
	if (<= n 1)
		1
		(* n (factorial (- n 1)))

print "Factorial of 5:" (factorial 5)

// 2. Closure (Counter)
def_func make_counter (start)
	def count start
	lambda ()
		set! count (+ count 1)
		count

def c1 (make_counter 10)
print "Counter c1:" (c1)
print "Counter c1:" (c1)

// 3. Advanced Macro: for-each using lambda
def_macro for_each (item dummy collection body)
	`((lambda (_coll)
		(begin
			def _idx 0
			while (< _idx (len _coll))
				(lambda (,item) ,body) (at _coll _idx)
				set! _idx (+ _idx 1))) ,collection)

print "--- Testing for_each ---"
def my_list [10 20 30]
for_each x in my_list
	print "Item:" x

// 4. File IO
def log_file "log.txt"
io_write log_file "Log Entry"
print "Log exists?" (io_exists? log_file)
