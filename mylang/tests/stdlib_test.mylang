// Test While Loop and set!
def i 0
while (lt i 5)
	def i (+ i 1)
	print "Loop index:" i

// Test Container Operations
def my_arr [1 2 3]
print "Array length:" (len my_arr)
print "Array at 1:" (at my_arr 1)

def my_arr (push my_arr 4)
print "New Array:" my_arr
print "New length:" (len my_arr)

def my_dict {a: 1 b: 2}
print "Dict length:" (len my_dict)
print "Dict has a?" (has? my_dict 'a)
print "Dict has c?" (has? my_dict 'c)

// Test Type Predicates
print "Is nil nil?" (nil? nil)
print "Is 123 num?" (num? 123)
print "Is 'abc atom?" (atom? 'abc)
print "Is (list 1) list?" (list? (list 1))

// Test Math
print "10 mod 3 =" (mod 10 3)
